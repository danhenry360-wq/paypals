---
import '../styles/global.css';

interface Props {
  title?: string;
  authed?: boolean;
}
const { title = 'PayPal', authed = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    {
      authed && (
        <header class="header">
          <div class="container">
            <a href="/dashboard" class="brand">
              <svg width="34" height="34" viewBox="0 0 100 100" fill="none" style="vertical-align:middle; margin-right:0.4rem;" aria-hidden="true">
                <path d="M27 8h28c14 0 23 7 23 19 0 9-6 15-15 17 8 1 14 7 14 16 0 13-10 21-25 21H27V8z" fill="#253b80"/>
                <path d="M27 8h28c14 0 23 7 23 19 0 9-6 15-15 17 8 1 14 7 14 16 0 13-10 21-25 21H27V8z" fill="#179bd7" transform="translate(7 4)"/>
                <path d="M27 8h28c14 0 23 7 23 19 0 9-6 15-15 17 8 1 14 7 14 16 0 13-10 21-25 21H27V8z" fill="#253b80" transform="translate(0 0)"/>
              </svg>
              <span>PayPal</span>
            </a>
            <nav>
              <a href="/dashboard">Dashboard</a>
              <a href="/send">Send</a>
              <a href="/request">Request</a>
              <a href="/activity">Activity</a>
              <a href="/profile">Profile</a>
              <a href="/logout" id="logout-link">Log out</a>
            </nav>
          </div>
        </header>
      )
    }
    <slot />

    <script>
      document.getElementById('logout-link')?.addEventListener('click', (e) => {
        e.preventDefault();
        import('../lib/wallet').then(({ logout }) => {
          logout();
          window.location.href = '/login';
        });
      });
    </script>
  </body>
</html>
