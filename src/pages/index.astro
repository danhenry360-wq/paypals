---
import App from '../layouts/App.astro';
---
<App title="Paypals">
  <div class="container" style="text-align:center; padding-top:4rem;">
    <h1 style="font-size:2.2rem;">Paypals</h1>
    <p class="muted" style="margin-bottom:2rem;">A local demo wallet inspired by PayPal.</p>
    <div class="row" style="justify-content:center;">
      <a class="btn" href="/login">Log in</a>
      <a class="btn secondary" href="/signup">Sign up</a>
    </div>
  </div>
  <script>
    import { seedDemo, getCurrentUser } from '../lib/wallet';
    seedDemo();
    if (getCurrentUser()) window.location.href = '/dashboard';
  </script>
</App>
