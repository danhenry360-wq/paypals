---
import App from '../layouts/App.astro';
---
<App title="PayPal">
  <div class="container" style="text-align:center; padding-top:4rem;">
    <h1 style="font-size:2.2rem;">
      <svg width="48" height="48" viewBox="0 0 100 100" fill="none" style="vertical-align:middle; margin-right:0.4rem;" aria-hidden="true">
        <path d="M27 8h28c14 0 23 7 23 19 0 9-6 15-15 17 8 1 14 7 14 16 0 13-10 21-25 21H27V8z" fill="#253b80"/>
        <path d="M27 8h28c14 0 23 7 23 19 0 9-6 15-15 17 8 1 14 7 14 16 0 13-10 21-25 21H27V8z" fill="#179bd7" transform="translate(7 4)"/>
        <path d="M27 8h28c14 0 23 7 23 19 0 9-6 15-15 17 8 1 14 7 14 16 0 13-10 21-25 21H27V8z" fill="#253b80" transform="translate(0 0)"/>
      </svg>
      PayPal
    </h1>
    <p class="muted" style="margin-bottom:2rem;">A local demo wallet inspired by PayPal.</p>
    <div class="row" style="justify-content:center;">
      <a class="btn" href="/login">Log in</a>
      <a class="btn secondary" href="/signup">Sign up</a>
    </div>
  </div>
  <script>
    import { seedDemo, getCurrentUser } from '../lib/wallet';
    seedDemo();
    if (getCurrentUser()) window.location.href = '/dashboard';
  </script>
</App>
